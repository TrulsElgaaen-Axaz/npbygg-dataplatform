{
	"name": "load_sharepoint_site",
	"properties": {
		"activities": [
			{
				"name": "Update Site data",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"additionalHeaders": {
							"Authorization": {
								"value": "@concat(\n    'Bearer ',\n    pipeline().parameters.sp_access_token\n)",
								"type": "Expression"
							}
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "LakehouseWriteSettings",
							"copyBehavior": "PreserveHierarchy"
						},
						"formatSettings": {
							"type": "JsonWriteSettings",
							"filePattern": "setOfObjects"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "sharepoint_site_details",
						"type": "DatasetReference",
						"parameters": {
							"site_id": {
								"value": "@pipeline().parameters.site_id",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "fabric_bronze_lakehouse_site_details",
						"type": "DatasetReference",
						"parameters": {
							"site_id": {
								"value": "@pipeline().parameters.site_id",
								"type": "Expression"
							}
						}
					}
				]
			},
			{
				"name": "For each list",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.lists",
						"type": "Expression"
					},
					"isSequential": false,
					"activities": [
						{
							"name": "Load Sharepoint List Items",
							"type": "ExecutePipeline",
							"dependsOn": [],
							"policy": {
								"secureInput": true
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "load_sharepoint_list_items",
									"type": "PipelineReference"
								},
								"waitOnCompletion": false,
								"parameters": {
									"batch_timestamp": {
										"value": "@pipeline().parameters.batch_timestamp",
										"type": "Expression"
									},
									"batch_id": {
										"value": "@pipeline().parameters.batch_id",
										"type": "Expression"
									},
									"list_id": {
										"value": "@item().id",
										"type": "Expression"
									},
									"site_id": {
										"value": "@pipeline().parameters.site_id",
										"type": "Expression"
									},
									"sp_access_token": {
										"value": "@pipeline().parameters.sp_access_token",
										"type": "Expression"
									},
									"from_date": {
										"value": "@pipeline().parameters.from_date",
										"type": "Expression"
									},
									"to_date": {
										"value": "@pipeline().parameters.to_date",
										"type": "Expression"
									},
									"expand": {
										"value": "@item().expand",
										"type": "Expression"
									}
								}
							}
						}
					]
				}
			}
		],
		"parameters": {
			"site_id": {
				"type": "string"
			},
			"lists": {
				"type": "array",
				"defaultValue": []
			},
			"batch_id": {
				"type": "string"
			},
			"batch_timestamp": {
				"type": "string"
			},
			"sp_access_token": {
				"type": "securestring"
			},
			"from_date": {
				"type": "string"
			},
			"to_date": {
				"type": "string"
			}
		},
		"annotations": [],
